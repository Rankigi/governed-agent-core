# RANKIGI Governed Agent
# Born governed. Every action recorded.
# rankigi.com

# -----------------------------------------
# LLM PROVIDER
# RANKIGI is model agnostic.
# Configure one or more.
# Set LLM_PROVIDER to choose explicitly.
# If not set, auto-detects from available keys.
# -----------------------------------------

# Provider selection (optional)
# Options: openai | anthropic | ollama
LLM_PROVIDER=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local models)
# Run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# -----------------------------------------
# RANKIGI GOVERNANCE LAYER
# Get from: rankigi.com/dashboard/agents/new
# -----------------------------------------
RANKIGI_API_KEY=rnk_api_...
RANKIGI_AGENT_ID=RNK-AGT-...

# -----------------------------------------
# INTERFACES (optional)
# -----------------------------------------

# Telegram bot
# Create at: t.me/BotFather
TELEGRAM_BOT_TOKEN=

# -----------------------------------------
# SELF-MODEL
# The outer loop builds a self-model from
# governed history. Speed is the intelligence
# metric — compiled patterns skip reasoning.
# -----------------------------------------

# How many matches before a pattern compiles
PATTERN_COMPILE_THRESHOLD=5

# Minimum confidence to compile (0.0-1.0)
PATTERN_COMPILE_CONFIDENCE=0.8

# How many timing runs to keep in memory
TIMING_CURVE_WINDOW=100

# Print self-model dashboard on startup
SELF_MODEL_VERBOSE=true
