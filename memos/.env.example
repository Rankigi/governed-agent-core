# MemOS sidecar environment.
# Copy to .env and edit. Then bring up:
#   docker compose -f memos/docker-compose.yml --env-file memos/.env up -d

# MemOS API authentication
MEMOS_API_KEY=localdev_memos_key

# Optional — pass through provider keys to MemOS for embedding generation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
